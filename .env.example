# VulnFix POC — shared env file for agent-api and tools-api.
# Copy to `.env` in this same directory and fill in real values.
# agent-api reads AGENT_API_* keys; tools-api reads TOOLS_API_* keys.
# Process env vars override values defined here.

# ─────────────────────────────────────────────────────────────
# Tools API
# ─────────────────────────────────────────────────────────────

# Absolute path to the directory where per-run workspaces are checked out.
# Must exist and be writable by the tools-api process.
TOOLS_API_WORKSPACE_ROOT=/tmp/vulnfix-workspaces

# Subprocess hard timeouts (seconds).
TOOLS_API_GIT_TIMEOUT_SECONDS=120
TOOLS_API_NPM_AUDIT_TIMEOUT_SECONDS=120
TOOLS_API_NPM_INSTALL_TIMEOUT_SECONDS=300

# Max concurrent workspaces on disk.
TOOLS_API_MAX_WORKSPACES=50

# GitHub Personal Access Token with `repo` scope. Required for the
# /pull-request endpoint (branch push + PR creation).
TOOLS_API_GITHUB_TOKEN=ghp_replace_me

# ─────────────────────────────────────────────────────────────
# Agent API → Tools API
# ─────────────────────────────────────────────────────────────

AGENT_API_TOOLS_API_BASE_URL=http://localhost:8001
AGENT_API_TOOLS_API_KEY=pick-something-random
AGENT_API_TOOLS_API_TIMEOUT_SECONDS=360

# ─────────────────────────────────────────────────────────────
# Agent API — LLM provider
# ─────────────────────────────────────────────────────────────

# Provider: "openai" | "anthropic" | "github"
AGENT_API_LLM_PROVIDER=openai
AGENT_API_LLM_MODEL=gpt-4.1-nano-2025-04-14
AGENT_API_LLM_TEMPERATURE=0.0
AGENT_API_LLM_MAX_TOKENS=4096

# Only the key for your chosen provider is required; leave others blank.
AGENT_API_OPENAI_API_KEY=sk-replace-me
AGENT_API_ANTHROPIC_API_KEY=
AGENT_API_GH_API_TOKEN=

# GitHub Models (only when AGENT_API_LLM_PROVIDER=github).
AGENT_API_GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
AGENT_API_GITHUB_MODELS_TOKEN=

# ─────────────────────────────────────────────────────────────
# Agent API — remediation workflow
# ─────────────────────────────────────────────────────────────

# Hard cap on targeted package updates per run.
AGENT_API_MAX_TARGETED_UPDATES_PER_RUN=25

# Git author identity used on commits created by tools-api.
AGENT_API_COMMIT_AUTHOR_NAME=VulnFix Bot
AGENT_API_COMMIT_AUTHOR_EMAIL=vulnfix-bot@example.com

# Prefix for auto-generated PR branch names (final form: "<prefix><ws-id8>").
AGENT_API_PR_BRANCH_PREFIX=vulnfix/

# ─────────────────────────────────────────────────────────────
# Agent API — batch CSV upload
# ─────────────────────────────────────────────────────────────

# Base URL prepended to the CSV `Location` slug (<owner>/<repo>).
AGENT_API_GITHUB_HOST=https://github.com/

# Max concurrent per-repo remediations; additional repos queue.
AGENT_API_BATCH_REMEDIATION_CONCURRENCY=3

# Truncate CSV Description before handing to the planner (keeps LLM context bounded).
AGENT_API_CSV_DESCRIPTION_MAX_CHARS=500
